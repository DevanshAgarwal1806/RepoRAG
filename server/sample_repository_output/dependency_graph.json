    {
      "name": "DocumentProcessor.remove_punctuation",
      "language": "python",
      "file": "server/sample_repository/text_processor.py",
      "start_line": 6,
      "end_line": 8,
      "docstring": null,
      "source": "def remove_punctuation(self, text):\n        # Calls string methods (.replace)\n        return text.replace(\".\", \"\").replace(\",\", \"\")",
      "id": "server/sample_repository/text_processor.py::DocumentProcessor.remove_punctuation::5"
    },
    {
      "name": "DocumentProcessor.clean_text",
      "language": "python",
      "file": "server/sample_repository/text_processor.py",
      "start_line": 10,
      "end_line": 16,
      "docstring": "Cleans the text by removing punctuation and converting to lowercase.",
      "source": "def clean_text(self, raw_text):\n        \"\"\"Cleans the text by removing punctuation and converting to lowercase.\"\"\"\n        # Calls another method within the same class\n        no_punct = self.remove_punctuation(raw_text)\n        \n        # Calls string method (.lower)\n        return no_punct.lower()",
      "id": "server/sample_repository/text_processor.py::DocumentProcessor.clean_text::9"
    },
    {
      "name": "run_pipeline",
      "language": "python",
      "file": "server/sample_repository/main.py",
      "start_line": 4,
      "end_line": 15,
      "docstring": "Main execution function for the pipeline.",
      "source": "def run_pipeline(document_text):\n    \"\"\"Main execution function for the pipeline.\"\"\"\n    processor = DocumentProcessor([\"the\", \"is\", \"and\"])\n    \n    # Call to object method\n    cleaned_doc = processor.clean_text(document_text)\n    \n    # Standalone function call\n    score = calculate_bm25(5.0, 1.2)\n    \n    print(f\"Processed document score: {score}\")\n    return score",
      "id": "server/sample_repository/main.py::run_pipeline::3"
    },
    {
