    {
      "name": "decorator",
      "language": "python",
      "file": "server/sample_repository/fetch.py",
      "start_line": 6,
      "end_line": 14,
      "docstring": null,
      "source": "def decorator(func):\n        @functools.wraps(func)\n        async def wrapper(*args, **kwargs):\n            for i in range(max_attempts):\n                try:\n                    return await func(*args, **kwargs)\n                except Exception:\n                    pass\n        return wrapper",
