      "id": "server/sample_repository/fetch.py::wrapper::6"
    },
    {
      "name": "decorator",
      "language": "python",
      "file": "server/sample_repository/fetch.py",
      "start_line": 6,
      "end_line": 14,
      "docstring": null,
      "source": "def decorator(func):\n        @functools.wraps(func)\n        async def wrapper(*args, **kwargs):\n            for i in range(max_attempts):\n                try:\n                    return await func(*args, **kwargs)\n                except Exception:\n                    pass\n        return wrapper",
      "id": "server/sample_repository/fetch.py::decorator::5"
    },
    {
      "name": "retry",
      "language": "python",
      "file": "server/sample_repository/fetch.py",
      "start_line": 5,
      "end_line": 15,
      "docstring": null,
      "source": "def retry(max_attempts=3):\n    def decorator(func):\n        @functools.wraps(func)\n        async def wrapper(*args, **kwargs):\n            for i in range(max_attempts):\n                try:\n                    return await func(*args, **kwargs)\n                except Exception:\n                    pass\n        return wrapper\n    return decorator",
      "id": "server/sample_repository/fetch.py::retry::4"
    },
    {
      "name": "fetch_data",
      "language": "python",
      "file": "server/sample_repository/fetch.py",
      "start_line": 17,
      "end_line": 24,
      "docstring": "Fetches data from the given URL asynchronously.",
      "source": "@retry(max_attempts=5)\nasync def fetch_data(url):\n    \"\"\"Fetches data from the given URL asynchronously.\"\"\"\n    reader, writer = await asyncio.open_connection(url, 80)\n    writer.write(b\"GET / HTTP/1.0\\r\\n\\r\\n\")\n    data = await reader.read(100)\n    writer.close()\n    return data",
      "id": "server/sample_repository/fetch.py::fetch_data::16"
    },
    {
      "name": "process_batch",
      "language": "python",
      "file": "server/sample_repository/fetch.py",
      "start_line": 26,
      "end_line": 28,
      "docstring": null,
      "source": "async def process_batch(items):\n    results = await asyncio.gather(*[fetch_data(item) for item in items])\n    return results",
      "id": "server/sample_repository/fetch.py::process_batch::25"
    },
    {
      "name": "__main__",
      "language": "python",
      "file": "server/sample_repository/fetch.py",
      "start_line": 30,
      "end_line": 31,
      "docstring": null,
      "source": "if __name__ == \"__main__\":\n    asyncio.run(process_batch([\"example.com\", \"test.com\"]))",
      "id": "server/sample_repository/fetch.py::__main__::29"
    },
    {
      "name": "calculate_bm25",
      "language": "python",
      "file": "server/sample_repository/math_utils.py",
      "start_line": 1,
      "end_line": 4,
      "docstring": "Calculates the BM25 score for a given term.",
      "source": "def calculate_bm25(tf, idf):\n    \"\"\"Calculates the BM25 score for a given term.\"\"\"\n    # Simplified for testing\n    return tf * idf",
      "id": "server/sample_repository/math_utils.py::calculate_bm25::0"
    },
    {
      "name": "normalize_score",
      "language": "python",
      "file": "server/sample_repository/math_utils.py",
      "start_line": 6,
      "end_line": 8,
      "docstring": null,
      "source": "def normalize_score(score):\n    # Notice this function intentionally lacks a docstring\n    return score / 100.0",
      "id": "server/sample_repository/math_utils.py::normalize_score::5"
