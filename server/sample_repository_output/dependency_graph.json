      "docstring": null,
      "source": "export async function fetchLegacyUserData(userId) {\n    try {\n        const response = await fetch(`/api/v1/users/${userId}`);\n        return await response.json();\n    } catch (error) {\n        console.error(\"Failed to fetch user:\", error);\n        return null;\n    }\n}",
