    {
      "name": "retry",
      "language": "python",
      "file": "server/sample_repository/fetch.py",
      "start_line": 5,
      "end_line": 15,
      "docstring": null,
      "source": "def retry(max_attempts=3):\n    def decorator(func):\n        @functools.wraps(func)\n        async def wrapper(*args, **kwargs):\n            for i in range(max_attempts):\n                try:\n                    return await func(*args, **kwargs)\n                except Exception:\n                    pass\n        return wrapper\n    return decorator",
      "id": "server/sample_repository/fetch.py[5-15]:retry"
    },
    {
      "name": "fetch_data",
      "language": "python",
      "file": "server/sample_repository/fetch.py",
      "start_line": 17,
      "end_line": 24,
      "docstring": "Fetches data from the given URL asynchronously.",
      "source": "@retry(max_attempts=5)\nasync def fetch_data(url):\n    \"\"\"Fetches data from the given URL asynchronously.\"\"\"\n    reader, writer = await asyncio.open_connection(url, 80)\n    writer.write(b\"GET / HTTP/1.0\\r\\n\\r\\n\")\n    data = await reader.read(100)\n    writer.close()\n    return data",
      "id": "server/sample_repository/fetch.py[17-24]:fetch_data"
    },
    {
      "name": "process_batch",
      "language": "python",
      "file": "server/sample_repository/fetch.py",
      "start_line": 26,
      "end_line": 28,
      "docstring": null,
      "source": "async def process_batch(items):\n    results = await asyncio.gather(*[fetch_data(item) for item in items])\n    return results",
      "id": "server/sample_repository/fetch.py[26-28]:process_batch"
    },
