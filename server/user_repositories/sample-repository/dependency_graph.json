    {
      "name": "fetchLegacyUserData",
      "language": "javascript",
      "file": "server/sample_repository/frontend/legacy_portal/api_client.js",
      "start_line": 5,
      "end_line": 13,
      "docstring": null,
      "source": "export async function fetchLegacyUserData(userId) {\n    try {\n        const response = await fetch(`/api/v1/users/${userId}`);\n        return await response.json();\n    } catch (error) {\n        console.error(\"Failed to fetch user:\", error);\n        return null;\n    }\n}",
      "id": "server/sample_repository/frontend/legacy_portal/api_client.js[5-13]:fetchLegacyUserData"
